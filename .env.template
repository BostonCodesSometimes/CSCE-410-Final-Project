# LitePack-RAG environment configuration template
# -----------------------------------------------
# Copy this file to .env and fill in real values before running the project.
#
#   cp .env.template .env
#
# .env is git-ignored; this template is tracked so teammates can onboard easily.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=<your-pinecone-api-key>
PINECONE_INDEX_NAME=<your-pinecone-index-name>
PINECONE_HOST=<your-pinecone-host-url>        # e.g. https://my-index-xxxx.svc.aped-4627-b74a.pinecone.io
PINECONE_REGION=<your-pinecone-region>        # e.g. us-east-1

# ── Model selection ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small        # OpenAI embedding model
LLM_MODEL=gpt-4o-mini                        # OpenAI chat completion model

# ── Generator settings ────────────────────────────────────────────────────────
TEMPERATURE=0.1
SEED=100
MAX_OUTPUT_TOKENS=150
GPUS=                                         # unused (OpenAI API pipeline)

# ── NCBI / PubMed (required for data_load.py) ────────────────────────────────
NCBI_EMAIL=<your-email@example.com>           # required by Biopython Entrez
NCBI_API_KEY=<your-ncbi-api-key>              # optional but raises rate limits
